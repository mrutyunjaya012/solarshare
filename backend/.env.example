# MongoDB Atlas (recommended) — Database Access user + Network Access IP allowlist
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/solarshare?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/solarshare?retryWrites=true&w=majority

# Local MongoDB alternative:
# MONGO_URI=mongodb://127.0.0.1:27017/solarshare

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
PORT=5001
# Required only to create an admin account through the registration screen.
ADMIN_REGISTRATION_CODE=choose-a-private-admin-code
